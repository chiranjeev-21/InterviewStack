# Shared secret with the token-generator repo.
# Generate a strong value: openssl rand -base64 48
JWT_SECRET=change-me-in-production-use-openssl-rand-base64-48

# Production database settings used by docker-compose and the prod profile.
DATABASE_URL=jdbc:postgresql://postgres:5432/interviewbank
DATABASE_USERNAME=ib_user
DATABASE_PASSWORD=ib_pass
